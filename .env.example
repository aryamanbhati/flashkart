# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is committed as the source of truth for what's configurable.

# --- Runtime ---
NODE_ENV=development

# --- API ---
API_PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- MongoDB ---
# Inside docker-compose, the hostname is the service name (`mongo`).
# When running the api locally against dockerized mongo, use localhost.
MONGO_URI=mongodb://mongo:27017/flashkart

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- JWT ---
# CHANGE THESE. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Rate limit ---
# Optional shared secret that lets internal load-test scripts (buyStorm etc.)
# bypass the /buy rate limit. Leave EMPTY in prod. Non-empty in dev/staging.
RATE_LIMIT_BYPASS_TOKEN=dev-bypass-token
